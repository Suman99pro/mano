#!/usr/bin/env bash
#
# mano - "man" + AI examples
# Shows practical usage examples for a terminal command, generated by a
# local LLaMA-family model (via Ollama), grounded in the real man page.
#
# Usage:
#   mano <command>              Show cached or freshly generated examples
#   mano -r <command>           Force regenerate (ignore cache)
#   mano -m <model> <command>   Use a specific Ollama model (default: llama3.2)
#
# Requirements:
#   - ollama installed and running (https://ollama.com)
#   - a pulled model, e.g.:  ollama pull llama3.2
#
set -euo pipefail

MODEL="${MANO_MODEL:-llama3.2}"
CACHE_DIR="${MANO_CACHE_DIR:-$HOME/.cache/mano}"
FORCE=0

usage() {
    echo "Usage: mano [-r] [-m MODEL] <command>"
    echo "  -r          force regeneration, ignore cache"
    echo "  -m MODEL    ollama model to use (default: $MODEL)"
    exit 1
}

while getopts ":rm:h" opt; do
    case "$opt" in
        r) FORCE=1 ;;
        m) MODEL="$OPTARG" ;;
        h) usage ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

CMD="${1:-}"
[ -z "$CMD" ] && usage

if ! command -v ollama >/dev/null 2>&1; then
    echo "Error: 'ollama' is not installed or not on PATH." >&2
    echo "Install it from https://ollama.com and run: ollama pull $MODEL" >&2
    exit 1
fi

mkdir -p "$CACHE_DIR"
CACHE_FILE="$CACHE_DIR/${CMD}__${MODEL}.txt"

if [ "$FORCE" -eq 0 ] && [ -f "$CACHE_FILE" ]; then
    cat "$CACHE_FILE"
    exit 0
fi

# --- Pull the real man page for grounding (NAME/SYNOPSIS/DESCRIPTION only,
# to keep the prompt short and avoid the model hallucinating flags) ---
if ! MAN_TEXT=$(man "$CMD" 2>/dev/null | col -bx 2>/dev/null); then
    MAN_TEXT=""
fi

if [ -z "$MAN_TEXT" ]; then
    echo "Warning: no man page found for '$CMD'. Asking the model from general knowledge only." >&2
    CONTEXT="(No man page available for '$CMD'.)"
else
    # Trim to the first ~120 lines: name/synopsis/description/options is
    # almost always covered within that, keeps prompt small and fast.
    CONTEXT=$(echo "$MAN_TEXT" | head -n 120)
fi

PROMPT=$(cat <<EOF
You are a terminal assistant. Below is the man page excerpt for the command '$CMD'.
Using ONLY real, valid flags/options that plausibly belong to this command
(prefer ones shown in the excerpt; do not invent flags that contradict it),
write 5-8 practical, real-world usage examples.

Format strictly as:
  $ <command line>
      <one line explanation>

No preamble, no markdown headers, no closing remarks. Just the example list.

--- MAN PAGE EXCERPT ---
$CONTEXT
--- END EXCERPT ---
EOF
)

echo "Generating examples for '$CMD' using model '$MODEL'..." >&2

RESPONSE=$(ollama run "$MODEL" "$PROMPT" 2>/dev/null)

echo "$RESPONSE" | tee "$CACHE_FILE"
